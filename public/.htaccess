# Canonical URL: https://taxirabatairoport.com/
# All four variants redirect here (301 permanent):
#   http://taxirabatairoport.com      -> https://taxirabatairoport.com/
#   http://www.taxirabatairoport.com  -> https://taxirabatairoport.com/
#   https://www.taxirabatairoport.com -> https://taxirabatairoport.com/
#   https://taxirabatairoport.com     -> no redirect (canonical)
#
# Charset in HTTP response (fixes "charset encoding missing in HTTP header")
AddDefaultCharset UTF-8

# Some hosts serve .js as text/plain; ES modules require a JavaScript MIME type
<IfModule mod_mime.c>
  AddType application/javascript .js
  AddType application/javascript .mjs
  AddType text/css .css
  AddType application/wasm .wasm
</IfModule>
<IfModule mod_headers.c>
  <FilesMatch "\.(js|mjs)$">
    Header set Content-Type "application/javascript; charset=utf-8"
  </FilesMatch>
  <FilesMatch "\.css$">
    Header set Content-Type "text/css; charset=utf-8"
  </FilesMatch>
</IfModule>

RewriteEngine On
RewriteBase /

# 1) Force HTTPS (301). Handles: http -> https (for both www and non-www).
#    If behind a proxy, server may see HTTP; use X-Forwarded-Proto when set.
RewriteCond %{HTTPS} off
RewriteCond %{HTTP:X-Forwarded-Proto} !https
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# 2) Force non-www (301). Handles: https://www.taxirabatairoport.com -> https://taxirabatairoport.com/
RewriteCond %{HTTP_HOST} ^www\.taxirabatairoport\.com [NC]
RewriteRule ^ https://taxirabatairoport.com%{REQUEST_URI} [L,R=301]

# 3) Never rewrite Vite bundles or static files to index.html. Without this, a missing
#    or mis-resolved /assets/*.js request gets HTML → "wrong MIME" for module scripts.
RewriteCond %{REQUEST_URI} ^/assets/ [OR]
RewriteCond %{REQUEST_URI} \.(?:js|mjs|css|map|json|png|jpe?g|gif|webp|svg|ico|woff2?|woff|ttf|mp4|txt|xml|html)$ [NC]
RewriteRule ^ - [L]

# SPA fallback: serve index.html for non-file routes (enables custom 404 via React Router)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.html [L]

# HSTS: force HTTPS for 1 year (recommended for SEO/security)
# Content-Language so SEO checkers and crawlers detect default language (fr)
<IfModule mod_headers.c>
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
  Header set Content-Language "fr"
</IfModule>

# Cache static assets (improves repeat visits, ~28 KiB savings)
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType video/mp4 "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType font/woff2 "access plus 1 year"
</IfModule>
<IfModule mod_headers.c>
  <FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|mp4|css|js|woff2)$">
    Header set Cache-Control "public, max-age=31536000"
  </FilesMatch>
</IfModule>
